# Copy to .env and fill in. None of these are required to run unit tests.

# Google AI Studio key (free tier) — used as frontier baseline + LLM-as-judge
GOOGLE_API_KEY=

# HuggingFace Hub — needed only when pushing adapters / datasets / model cards
HF_TOKEN=

# Weights & Biases (free personal tier) — set to disable / online / offline
WANDB_API_KEY=
WANDB_MODE=online
WANDB_PROJECT=earningslora

# --- EarningsLoRA settings (all optional; sensible defaults in src/earningslora/config.py)
EARNINGSLORA_BASE_MODEL=meta-llama/Llama-3.2-3B-Instruct
EARNINGSLORA_ADAPTER_REPO=mathieu-calvo/llama-3.2-3b-earningslora
EARNINGSLORA_DATASET_REPO=mathieu-calvo/ectsum-chat
EARNINGSLORA_JUDGE_MODEL=gemini-2.5-flash
EARNINGSLORA_FRONTIER_MODEL=gemini-2.5-flash
EARNINGSLORA_MAX_SEQ_LEN=4096
EARNINGSLORA_CACHE_DIR=
